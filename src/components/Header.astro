---
import { SITE_TITLE } from "../consts";
import HeaderLink from "./HeaderLink.astro";
import ThemeToggle from "./ThemeToggle.astro";
import { Icon } from "astro-icon/components";
---

<header class="m-0 px-4 bg-background border-b border-border transition-colors duration-300 font-sans">
  <nav class="flex items-center justify-between">
    <h2 class="m-0 text-[1em] font-semibold">
      <a href="/" class="no-underline text-foreground">{SITE_TITLE}</a>
    </h2>
    <div class="flex items-center">
      <HeaderLink href="/">Home</HeaderLink>
      <HeaderLink href="/blog">Blog</HeaderLink>
      <HeaderLink href="/about">About</HeaderLink>
    </div>
    <div class="hidden md:flex items-center gap-2">
      <ThemeToggle />
      <a href="mailto:harshdevisha91@gmail.com" class="flex text-muted-foreground hover:text-foreground transition-colors">
        <span class="sr-only">Email me</span>
        <Icon name="lucide:mail" size={20} />
      </a>
      <a href="https://www.linkedin.com/in/harsh-devisha/" target="_blank" class="flex text-muted-foreground hover:text-foreground transition-colors">
        <span class="sr-only">Connect on LinkedIn</span>
        <Icon name="lucide:linkedin" size={20} />
      </a>
      <a href="https://github.com/lostcache" target="_blank" class="flex text-muted-foreground hover:text-foreground transition-colors">
        <span class="sr-only">Go to GitHub profile</span>
        <Icon name="lucide:github" size={20} />
      </a>
    </div>
  </nav>
</header>

<style>
  nav a {
    padding: 1em 0.5em;
    color: rgb(var(--black));
    border-bottom: 4px solid transparent;
    text-decoration: none;
  }
  nav a.active {
    border-bottom-color: var(--accent);
  }
</style>
