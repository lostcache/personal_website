---
interface Props {
  maxHeight?: string;
}

const { maxHeight = "400px" } = Astro.props;
const id = `code-${Math.random().toString(36).substr(2, 9)}`;
---

<div class="relative my-6">
  <div class="overflow-auto relative" style={`max-height: ${maxHeight}`} data-code-id={id}>
    <slot />
  </div>
  <button
    class="expand-btn absolute top-2 right-2 px-3 py-1.5 bg-[#0066cc] hover:bg-[#0052a3] text-white border-none rounded cursor-pointer text-[13px] flex items-center gap-1.5 z-10 transition-colors duration-200"
    data-target={id}
    type="button"
  >
    <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor">
      <path d="M1.5 1a.5.5 0 0 0-.5.5v4a.5.5 0 0 1-1 0v-4A1.5 1.5 0 0 1 1.5 0h4a.5.5 0 0 1 0 1h-4zM10 .5a.5.5 0 0 1 .5-.5h4A1.5 1.5 0 0 1 16 1.5v4a.5.5 0 0 1-1 0v-4a.5.5 0 0 0-.5-.5h-4a.5.5 0 0 1-.5-.5zM.5 10a.5.5 0 0 1 .5.5v4a.5.5 0 0 0 .5.5h4a.5.5 0 0 1 0 1h-4A1.5 1.5 0 0 1 0 14.5v-4a.5.5 0 0 1 .5-.5zm15 0a.5.5 0 0 1 .5.5v4a1.5 1.5 0 0 1-1.5 1.5h-4a.5.5 0 0 1 0-1h4a.5.5 0 0 0 .5-.5v-4a.5.5 0 0 1 .5-.5z"/>
    </svg>
    View Full
  </button>
</div>

<div class="code-modal fixed inset-0 z-[1000]" id={id}>
  <div class="modal-backdrop absolute inset-0 bg-black/80 backdrop-blur-sm"></div>
  <div class="relative w-[90vw] max-w-[1400px] h-[90vh] my-[5vh] mx-auto bg-[#1e1e1e] rounded-lg overflow-hidden shadow-[0_20px_60px_rgba(0,0,0,0.5)]">
    <button
      class="close-btn absolute top-3 right-3 w-9 h-9 bg-white/10 hover:bg-white/20 border-none rounded cursor-pointer flex items-center justify-center z-[1001] text-white transition-colors duration-200"
      type="button"
    >
      <svg width="24" height="24" viewBox="0 0 16 16" fill="currentColor">
        <path d="M2.146 2.854a.5.5 0 1 1 .708-.708L8 7.293l5.146-5.147a.5.5 0 0 1 .708.708L8.707 8l5.147 5.146a.5.5 0 0 1-.708.708L8 8.707l-5.146 5.147a.5.5 0 0 1-.708-.708L7.293 8 2.146 2.854Z"/>
      </svg>
    </button>
    <div class="modal-code h-full overflow-auto p-4"></div>
  </div>
</div>

<style>
  .code-modal { display: none; }
  .code-modal.active { display: block; }
  .modal-code > div { max-height: none !important; }
</style>

<script>
  function init() {
    const expandButtons = document.querySelectorAll('.expand-btn');

    expandButtons.forEach(btn => {
      const handler = () => {
        const targetId = btn.getAttribute('data-target');
        if (!targetId) return;

        const modal = document.getElementById(targetId);
        const codeContainer = document.querySelector(`[data-code-id="${targetId}"]`);

        if (modal && codeContainer) {
          const modalCode = modal.querySelector('.modal-code');
          if (modalCode) {
            modalCode.innerHTML = '';
            const codeClone = codeContainer.cloneNode(true) as HTMLElement;
            codeClone.style.maxHeight = 'none';
            codeClone.removeAttribute('data-code-id');
            modalCode.appendChild(codeClone);
          }
          modal.classList.add('active');
          document.body.style.overflow = 'hidden';
        }
      };

      btn.removeEventListener('click', handler);
      btn.addEventListener('click', handler);
    });

    const closeModal = (modal: Element) => {
      modal.classList.remove('active');
      document.body.style.overflow = '';
    };

    document.querySelectorAll('.close-btn').forEach(btn => {
      const handler = () => {
        const modal = btn.closest('.code-modal');
        if (modal) closeModal(modal);
      };
      btn.removeEventListener('click', handler);
      btn.addEventListener('click', handler);
    });

    document.querySelectorAll('.modal-backdrop').forEach(backdrop => {
      const handler = () => {
        const modal = backdrop.closest('.code-modal');
        if (modal) closeModal(modal);
      };
      backdrop.removeEventListener('click', handler);
      backdrop.addEventListener('click', handler);
    });

    const escHandler = (e: KeyboardEvent) => {
      if (e.key === 'Escape') {
        const activeModal = document.querySelector('.code-modal.active');
        if (activeModal) closeModal(activeModal);
      }
    };

    document.removeEventListener('keydown', escHandler);
    document.addEventListener('keydown', escHandler);
  }

  init();
  document.addEventListener('astro:page-load', init);
</script>
