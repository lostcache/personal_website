---
import Button from './ui/Button.astro';
import { Icon } from "astro-icon/components";

interface Props {
  maxHeight?: string;
}

const { maxHeight = "400px" } = Astro.props;
const id = `ec-${Math.random().toString(36).slice(2, 9)}`;
---

<div class="ec-wrap relative my-6" id={id} style={`--ec-max-h: ${maxHeight}`}>
  <div class="ec-preview" style={`max-height: var(--ec-max-h); overflow-y: auto;`}>
    <slot />
  </div>
  <Button
    variant="default"
    size="sm"
    class="ec-open absolute bottom-2 right-2"
  >
    <Icon name="lucide:maximize-2" size={14} />
    View Full
  </Button>

  <dialog class="ec-dialog fixed inset-0 z-50 bg-background border border-border rounded-lg shadow-lg w-[90vw] max-w-[1400px] h-[90vh] overflow-hidden m-auto" aria-label="Full code view">
    <Button
      variant="outline"
      size="icon"
      class="ec-close absolute top-3 right-3 z-10"
    >
      <Icon name="lucide:x" size={16} />
    </Button>
    <div class="ec-dialog-body h-full overflow-auto p-4"></div>
  </dialog>
</div>

<style>
  .ec-dialog::backdrop {
    background: rgba(0,0,0,.8);
    backdrop-filter: blur(4px);
  }

  .ec-dialog-body :global(.ec-preview) {
    max-height: none !important;
  }
</style>

<script>
  function initExpandableCode() {
    document.querySelectorAll<HTMLElement>('.ec-wrap').forEach(wrap => {
      const openBtn  = wrap.querySelector<HTMLButtonElement>('.ec-open');
      const closeBtn = wrap.querySelector<HTMLButtonElement>('.ec-close');
      const dialog   = wrap.querySelector<HTMLDialogElement>('.ec-dialog');
      const body     = wrap.querySelector<HTMLElement>('.ec-dialog-body');
      const preview  = wrap.querySelector<HTMLElement>('.ec-preview');

      if (!openBtn || !closeBtn || !dialog || !body || !preview) return;

      openBtn.addEventListener('click', () => {
        body.appendChild(preview);
        dialog.showModal();
      });

      const close = () => {
        wrap.insertBefore(preview, dialog);
        dialog.close();
      };

      closeBtn.addEventListener('click', close);

      dialog.addEventListener('click', (e) => {
        if (e.target === dialog) close();
      });
    });
  }

  initExpandableCode();
  document.addEventListener('astro:page-load', initExpandableCode);
</script>
