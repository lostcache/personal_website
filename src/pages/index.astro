---
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { SITE_TITLE, SITE_DESCRIPTION } from "../consts";
import { getCollection } from "astro:content";
import FormattedDate from "../components/FormattedDate.astro";
import { Icon } from "astro-icon/components";

const posts = (await getCollection("blog")).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const experience = [
  {
    title: "Graduate Research Assistant",
    company: "Kubishi | LMU Seaver School of Science and Engineering",
    date: "August 2025 - Present",
    tags: ["Python", "Mathematica", "Discrete Math", "Decentralized Algorithms", "Algorithm Analysis"],
  },
  {
    title: "Founding Engineer",
    company: "SetFindr",
    date: "December 2024 - May 2025",
    tags: ["Python", "FastAPI", "Node.js", "JWT", "Qdrant", "Google Maps API", "OAuth2", "OpenAI API", "AWS (EC2, S3)", "MongoDB"],
  },
  {
    title: "Data Specialist",
    company: "LMU Career and Professional Development Department",
    date: "August 2024 - May 2025",
    tags: ["ETL Pipelines", "Data Analysis", "Python", "SQL"],
  },
  {
    title: "Junior Software Engineer",
    company: "Nexuslink Services",
    date: "December 2021 - December 2023",
    tags: ["JWT Session Management", "REST APIs", "React-Redux", "ExpressJS", "MongoDB"],
  },
];
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body>
    <Header />
    <main class="w-full m-0 py-4 h-auto md:h-[calc(100vh-120px)] md:overflow-hidden">
      <div class="grid grid-cols-1 md:grid-cols-[25%_75%] h-full">

        <!-- Left: blog posts -->
        <div class="order-2 md:order-1 pl-4 pr-6 flex flex-col h-auto md:h-full md:overflow-hidden">
          <h2 class="text-left m-0 mb-2 text-[1.2rem] border-b border-[rgb(var(--gray-light))] shrink-0">
            Blogs ({posts.length})
          </h2>
          <div class="thin-scroll grid grid-cols-1 gap-4 overflow-y-visible md:overflow-y-auto flex-1 pb-4 min-h-0 pr-2">
            {posts.map((post) => (
              <a
                href={`/blog/${post.id}/`}
                class="bg-[rgb(var(--gray-light))] dark:bg-[#1a1a1a] rounded-xl p-4 no-underline text-[rgb(var(--black))] dark:text-white border border-black/5 dark:border-[#333] flex flex-col justify-between min-h-fit transition-all duration-200 hover:-translate-y-1 hover:shadow-[0_10px_20px_rgba(0,0,0,0.1)]"
              >
                <div>
                  <h3 class="m-0 text-[1rem] leading-tight mb-[0.2rem] line-clamp-2">{post.data.title}</h3>
                  <p class="m-0 mb-0 text-[0.85rem] text-[rgb(var(--gray))] leading-tight line-clamp-2">{post.data.description}</p>
                </div>
                <div class="text-[0.75rem] text-[rgb(var(--gray))] mt-[0.2rem] opacity-80">
                  Last Updated, <FormattedDate date={post.data.pubDate} />
                </div>
              </a>
            ))}
          </div>
        </div>

        <!-- Right: intro + projects + experience -->
        <div class="order-1 md:order-2 pr-4 md:pr-8 overflow-visible md:overflow-y-auto">

          <!-- Intro -->
          <div class="mb-4 text-center">
            <h2 class="mb-0">
              Hi, I'm Harsh
              <a target="_blank" href="https://www.youtube.com/watch?v=Zc7Gm2CpWfc" class="text-[0.5em] align-middle no-underline opacity-70">(Her-sh)</a>
            </h2>
            <div class="text-[15px]">He/Him, 100% Biodegradable, Cruelty-Free. Made in India</div>
            <p class="mt-4 text-[1.2rem] leading-relaxed">Hope you're well. Welcome to my digital garden.</p>
            <p class="mt-4 text-[1.2rem] leading-relaxed text-left">
              Recent <strong>CS grad from LMU</strong> (3.90 GPA) based in <strong>Los Angeles, CA</strong> with <strong>3+ YOE</strong> in <strong>web-dev</strong>. Interested in <strong>Systems Engineering and Distributed Systems</strong>.
            </p>
            <p class="text-[1.2rem] leading-relaxed text-left">
              I work on tools to help me vibe-code responsibly, automate things on my PC using LLMs, A distributed log and my hobby OS
            </p>
          </div>

          <!-- Projects -->
          <h2 class="text-left m-0 mb-2 text-[1.2rem] font-bold border-b border-[rgb(var(--gray-light))]">Work Collection</h2>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-8">
            <div class="bg-[rgb(var(--gray-light))] dark:bg-[#1a1a1a] rounded-xl p-4 border border-black/5 dark:border-[#333] flex flex-col justify-between transition-all duration-200 hover:-translate-y-0.5 hover:shadow-[0_4px_12px_rgba(0,0,0,0.1)]">
              <div>
                <div class="flex items-center justify-between mb-1">
                  <h3 class="m-0 text-[1.1rem] font-semibold text-[rgb(var(--black))] dark:text-white">dunno</h3>
                  <a href="https://github.com/lostcache/dunno" target="_blank" rel="noopener noreferrer" class="text-[rgb(var(--black))] dark:text-white opacity-70 hover:opacity-100 transition-opacity">
                    <Icon name="simple-icons:github" size={20} />
                  </a>
                </div>
                <p class="m-0 mb-0 text-[0.85rem] text-[rgb(var(--gray))] leading-snug">
                  CLI + web tool to manage codebase knowledge at file level for AI agents. Graph-structured context with SurrealDB backend, interactive visualization, and REST API.
                </p>
              </div>
              <div class="flex flex-wrap gap-1.5 mt-3">
                {["Rust", "SurrealDB", "TypeScript", "Graph DB"].map((tag) => (
                  <span class="bg-black/8 dark:bg-white/10 px-2.5 py-0.5 rounded text-[0.7rem] font-medium text-[rgb(var(--black))] dark:text-white">{tag}</span>
                ))}
              </div>
            </div>
          </div>

          <!-- Experience header -->
          <div class="flex justify-between items-center mb-2">
            <h2 class="m-0 text-[1.2rem] font-bold border-b border-[rgb(var(--gray-light))] flex-1">Experience</h2>
            <a
              href="/harsh_devisha_resume.pdf"
              target="_blank"
              rel="noopener noreferrer"
              class="ml-4 px-2 py-1.5 bg-black text-white no-underline rounded-lg text-base font-semibold inline-flex items-center gap-1.5 border-2 border-black transition-all duration-200 hover:-translate-y-0.5 hover:shadow-[0_4px_12px_rgba(0,0,0,0.2)] dark:bg-white dark:text-black dark:border-white dark:hover:shadow-[0_4px_12px_rgba(255,255,255,0.3)]"
            >
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path>
                <polyline points="15 3 21 3 21 9"></polyline>
                <line x1="10" y1="14" x2="21" y2="3"></line>
              </svg>
              Resume
            </a>
          </div>

          <!-- Experience cards -->
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-12">
            {experience.map((exp) => (
              <div class="bg-[rgb(var(--gray-light))] dark:bg-[#1a1a1a] rounded-xl p-4 border border-black/5 dark:border-[#333] transition-all duration-200 hover:-translate-y-0.5 hover:shadow-[0_4px_12px_rgba(0,0,0,0.1)]">
                <div class="mb-3">
                  <h3 class="m-0 mb-1 text-[1.1rem] font-semibold text-[rgb(var(--black))] dark:text-white">{exp.title}</h3>
                  <p class="m-0 mb-[0.2rem] text-[0.85rem] text-[rgb(var(--gray))]">{exp.company}</p>
                  <p class="m-0 text-[0.75rem] text-[rgb(var(--gray))] opacity-70">{exp.date}</p>
                </div>
                <div class="flex flex-wrap gap-1.5 mt-3">
                  {exp.tags.map((tag) => (
                    <span class="bg-black/8 dark:bg-white/10 px-2.5 py-0.5 rounded text-[0.7rem] font-medium text-[rgb(var(--black))] dark:text-white">{tag}</span>
                  ))}
                </div>
              </div>
            ))}
          </div>

        </div>
      </div>
    </main>
    <Footer />
  </body>
</html>
