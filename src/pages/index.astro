---
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { SITE_TITLE, SITE_DESCRIPTION } from "../consts";
import { getCollection } from "astro:content";
import FormattedDate from "../components/FormattedDate.astro";
import { Icon } from "astro-icon/components";
import Card from "../components/ui/Card.astro";
import CardTitle from "../components/ui/CardTitle.astro";
import CardDescription from "../components/ui/CardDescription.astro";
import CardContent from "../components/ui/CardContent.astro";
import Badge from "../components/ui/Badge.astro";
import Button from "../components/ui/Button.astro";
import Separator from "../components/ui/Separator.astro";

const posts = (await getCollection("blog")).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const experience = [
  {
    title: "Graduate Research Assistant",
    company: "Kubishi | LMU Seaver School of Science and Engineering",
    date: "August 2025 - Present",
    tags: ["Python", "Mathematica", "Discrete Math", "Decentralized Algorithms", "Algorithm Analysis"],
  },
  {
    title: "Founding Engineer",
    company: "SetFindr",
    date: "December 2024 - May 2025",
    tags: ["Python", "FastAPI", "Node.js", "JWT", "Qdrant", "Google Maps API", "OAuth2", "OpenAI API", "AWS (EC2, S3)", "MongoDB"],
  },
  {
    title: "Data Specialist",
    company: "LMU Career and Professional Development Department",
    date: "August 2024 - May 2025",
    tags: ["ETL Pipelines", "Data Analysis", "Python", "SQL"],
  },
  {
    title: "Junior Software Engineer",
    company: "Nexuslink Services",
    date: "December 2021 - December 2023",
    tags: ["JWT Session Management", "REST APIs", "React-Redux", "ExpressJS", "MongoDB"],
  },
];
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body>
    <Header />
    <main class="w-full m-0 py-4 h-auto md:h-[calc(100vh-120px)] md:overflow-hidden">
      <div class="grid grid-cols-1 md:grid-cols-[25%_75%] h-full">

        <!-- Left: blog posts -->
        <div class="order-2 md:order-1 pl-4 pr-6 flex flex-col h-auto md:h-full md:overflow-hidden">
          <h2 class="text-left m-0 mb-2 text-[1.2rem] shrink-0">
            Blogs ({posts.length})
          </h2>
          <Separator class="mb-4" />
          <div class="thin-scroll grid grid-cols-1 gap-4 overflow-y-visible md:overflow-y-auto flex-1 pb-4 min-h-0 pr-2">
            {posts.map((post) => (
              <Card class="no-underline text-foreground transition-all duration-200 hover:-translate-y-1 hover:shadow-lg cursor-pointer">
                <a href={`/blog/${post.id}/`} class="block">
                  <CardContent class="p-4">
                    <CardTitle class="text-base leading-tight mb-1 line-clamp-2">{post.data.title}</CardTitle>
                    <CardDescription class="text-sm leading-tight line-clamp-2">{post.data.description}</CardDescription>
                    <div class="text-xs text-muted-foreground mt-2 opacity-80">
                      Last Updated, <FormattedDate date={post.data.pubDate} />
                    </div>
                  </CardContent>
                </a>
              </Card>
            ))}
          </div>
        </div>

        <!-- Right: intro + projects + experience -->
        <div class="order-1 md:order-2 pr-4 md:pr-8 overflow-visible md:overflow-y-auto">

          <!-- Intro -->
          <div class="mb-4 text-center">
            <h2 class="mb-0">
              Hi, I'm Harsh
              <a target="_blank" href="https://www.youtube.com/watch?v=Zc7Gm2CpWfc" class="text-[0.5em] align-middle no-underline opacity-70">(Her-sh)</a>
            </h2>
            <div class="text-[15px]">He/Him, 100% Biodegradable, Cruelty-Free. Made in India</div>
            <p class="mt-4 text-[1.2rem] leading-relaxed">Hope you're well. Welcome to my digital garden.</p>
            <p class="mt-4 text-[1.2rem] leading-relaxed text-left">
              Recent <strong>CS grad from LMU</strong> (3.90 GPA) based in <strong>Los Angeles, CA</strong> with <strong>3+ YOE</strong> in <strong>web-dev</strong>. Interested in <strong>Systems Engineering and Distributed Systems</strong>.
            </p>
            <p class="text-[1.2rem] leading-relaxed text-left">
              I work on tools to help me vibe-code responsibly, automate things on my PC using LLMs, A distributed log and my hobby OS
            </p>
          </div>

          <!-- Projects -->
          <h2 class="text-left m-0 mb-2 text-[1.2rem] font-bold">Work Collection</h2>
          <Separator class="mb-4" />
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-8">
            <Card class="overflow-hidden transition-all duration-200 hover:-translate-y-0.5 hover:shadow-md">
              <img
                src="/dn_thumbnail.gif"
                alt="Dunno UI - Graph visualization of codebase knowledge"
                class="w-full"
                loading="lazy"
              />
              <CardContent class="p-4">
                <div class="flex items-center justify-between mb-2">
                  <CardTitle class="text-[1.1rem]">dunno</CardTitle>
                  <a href="https://github.com/lostcache/dunno" target="_blank" rel="noopener noreferrer" class="text-muted-foreground hover:text-foreground transition-colors">
                    <Icon name="simple-icons:github" size={20} />
                  </a>
                </div>
                <CardDescription class="text-sm leading-snug">
                  CLI + web tool to manage codebase knowledge at file level for AI agents. Graph-structured context with SurrealDB backend, interactive visualization, and REST API.
                </CardDescription>
                <div class="flex flex-wrap gap-1.5 mt-3">
                  {["Rust", "SurrealDB", "TypeScript", "Graph DB"].map((tag) => (
                    <Badge variant="secondary">{tag}</Badge>
                  ))}
                </div>
              </CardContent>
            </Card>
          </div>

          <!-- Experience header -->
          <div class="flex justify-between items-center mb-2">
            <h2 class="m-0 text-[1.2rem] font-bold flex-1">Experience</h2>
            <Button
              variant="default"
              as="a"
              href="/harsh_devisha_resume.pdf"
              target="_blank"
              rel="noopener noreferrer"
              class="ml-4"
            >
              <Icon name="lucide:external-link" size={16} />
              Resume
            </Button>
          </div>
          <Separator class="mb-4" />

          <!-- Experience cards -->
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-12">
            {experience.map((exp) => (
              <Card class="transition-all duration-200 hover:-translate-y-0.5 hover:shadow-md">
                <CardContent class="p-4">
                  <CardTitle class="text-[1.1rem] mb-1">{exp.title}</CardTitle>
                  <CardDescription class="text-sm mb-1">{exp.company}</CardDescription>
                  <p class="text-xs text-muted-foreground opacity-70">{exp.date}</p>
                  <div class="flex flex-wrap gap-1.5 mt-3">
                    {exp.tags.map((tag) => (
                      <Badge variant="secondary">{tag}</Badge>
                    ))}
                  </div>
                </CardContent>
              </Card>
            ))}
          </div>

        </div>
      </div>
    </main>
    <Footer />
  </body>
</html>
